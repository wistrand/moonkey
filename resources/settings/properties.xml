<properties>
    <!-- Connect IQ app settings (editable in Garmin Connect for beta/store installs;
         editable in the simulator settings editor). Sentinel defaults (-1 colour/tz,
         0 complication) mean "leave the native watch-face-config value alone", so
         these only override when the user actually changes them. See applyProperties. -->
    <property id="accentColor" type="number">-1</property>
    <property id="dataColor" type="number">-1</property>
    <property id="moonArcColor" type="number">-1</property>
    <property id="moonImage" type="number">0</property>
    <property id="text" type="string"></property>
    <property id="skipLabels" type="boolean">false</property>
    <property id="tz" type="number">0</property>
    <property id="compSE" type="number">0</property>
    <property id="compNE" type="number">0</property>
    <property id="compN" type="number">0</property>
    <property id="compS" type="number">0</property>
    <property id="compNW" type="number">0</property>
    <property id="compW" type="number">0</property>
    <property id="compE" type="number">0</property>
</properties>
